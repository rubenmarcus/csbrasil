---
import Layout from '../layouts/Layout.astro';
import { supabaseAdmin } from '../lib/supabase';
import { displayTime } from '../lib/fmt';
import { normalizeSocialUrl, socialAvatar, socialNet, NET_INFO, netIcon } from '../lib/social';
import { CHARS, charSvg } from '../lib/charsvg';
import { sideOf } from '../lib/side';

export const prerender = false;

let players: any[] = [], configured = !!supabaseAdmin;
let onlineNicks = new Set<string>();
if (supabaseAdmin) {
  const { data } = await supabaseAdmin.from('leaderboard').select('*');
  players = data ?? [];
  const { data: on } = await supabaseAdmin.from('online_now').select('nick');
  onlineNicks = new Set((on ?? []).map((r: any) => r.nick));
}
const PAGE_SIZE = 25;
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1', 10) || 1);
const totalPages = Math.max(1, Math.ceil(players.length / PAGE_SIZE));
const curPage = Math.min(page, totalPages);
const rows = players.slice((curPage - 1) * PAGE_SIZE, curPage * PAGE_SIZE);
---
<Layout title="Ranking global — CS BRASIL: Treta Suprema" description="Leaderboard global do CS BRASIL: os maiores abatedores da arena Treta Suprema.">
  <h1>🌐 RANKING GLOBAL</h1>
  {!configured && <p>Ranking ainda não configurado (envs do Supabase pendentes).</p>}
  {configured && players.length === 0 && <p>Ainda ninguém na arena. Seja o primeiro a cravar seu nome na treta: <a href="/">▶ JOGAR</a></p>}
  {players.length > 0 && (
    <table>
      <thead>
        <tr>
          <th>#</th><th>JOGADOR</th><th>PART.</th><th>VIT.</th><th>K/D</th><th>KILLS</th><th>MORTES</th><th>HS</th><th>SEQ.</th><th>TEMPO</th><th>LADO</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((p, i) => (
          <tr style={`${(curPage - 1) * PAGE_SIZE + i < 3 ? 'color:#ffd23f;font-weight:bold' : 'color:#c9bfa4'}`}>
            <td>{(curPage - 1) * PAGE_SIZE + i + 1}</td>
            <td>
              {(() => {
                const av = p.avatar_url || socialAvatar(p.social_link);
                if (av) return <img src={av} alt="" width="24" height="24" style="border-radius:50%;vertical-align:-6px;margin-right:6px;object-fit:cover">;
                if (p.last_character && CHARS[p.last_character]) {
                  const [, sc] = sideOf(p.matches_p, p.matches_b);
                  return (
                    <svg width="24" height="24" viewBox="688 36 120 120" style="vertical-align:-5px;margin-right:6px;border-radius:50%">
                      <Fragment set:html={charSvg(p.last_character, sc, `cav-r${i}`)} />
                    </svg>
                  );
                }
                return null;
              })()}
              {onlineNicks.has(p.nick) && <span title="online agora" style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#3fdd57;box-shadow:0 0 6px #3fdd57;margin-right:6px;vertical-align:1px"></span>}
              <a href={p.id ? `/u/${p.id}/${encodeURIComponent(p.nick)}` : `/u/${encodeURIComponent(p.nick)}`} style="color:inherit">{p.nick}</a>
              {(p.socials?.length ? p.socials : (p.social_link ? [{ net: socialNet(p.social_link), url: p.social_link }] : [])).map((s: any) => {
                const net = s.net || socialNet(s.url), info = NET_INFO[net] || NET_INFO.site;
                return (
                  <a href={normalizeSocialUrl(s.url)} target="_blank" rel="noopener" title={info.label}
                     style={`display:inline-block;margin-left:6px;vertical-align:-3px;color:${info.color};text-decoration:none`}
                     set:html={netIcon(net, 15)} />
                );
              })}
            </td>
            <td>{p.matches}</td>
            <td>{p.wins > 0 ? p.wins : "—"}</td>
            <td>{p.kd}</td>
            <td>{p.kills}</td>
            <td>{p.deaths}</td>
            <td>{p.headshots}</td>
            <td>{p.best_streak}×</td>
            <td>{displayTime(p)}</td>
            <td>
              <span style="color:#ff8080">{p.matches_p}P</span> × <span style="color:#9dff9d">{p.matches_b}B</span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
  {players.length > 0 && (
    <div style="display:flex;gap:10px;justify-content:center;margin-top:16px;font-size:13px;align-items:center">
      {curPage > 1 && <a href={`/ranking?page=${curPage - 1}`}>← ANTERIOR</a>}
      <span style="color:var(--amber-dim)">página {curPage}/{totalPages} · {players.length} jogadores</span>
      {curPage < totalPages && <a href={`/ranking?page=${curPage + 1}`}>PRÓXIMA →</a>}
    </div>
  )}
  <p style="margin-top:18px;font-size:13px">Atualiza a cada partida. Seu perfil público fica em <code>/u/seu-nick</code> — compartilhe a badge nas redes.</p>
</Layout>
