---
import Layout from '../../layouts/Layout.astro';
import { supabaseAdmin } from '../../lib/supabase';
import { displayTime } from '../../lib/fmt';
import { socialHref, socialAvatar, socialNet, NET_INFO } from '../../lib/social';
import { CHARS, charSvg } from '../../lib/charsvg';
import { sideOf } from '../../lib/side';

export const prerender = false;

// canônico: /u/<id>/<nick> · legado: /u/<nick> → redirect 301
const parts = (Astro.params.path || '').split('/').filter(Boolean);
let p: any = null, configured = !!supabaseAdmin;

if (supabaseAdmin) {
  if (parts.length === 2) {
    const { data } = await supabaseAdmin
      .from('stats').select('*, players!inner(id, nick, social_link, socials, avatar_url)')
      .eq('players.id', parts[0]).maybeSingle();
    p = data;
    if (p) {
      const real = p.players.nick;
      if (decodeURIComponent(parts[1]).toLowerCase() !== real.toLowerCase())
        return Astro.redirect(`/u/${p.players.id}/${encodeURIComponent(real)}`, 301);
    }
  } else if (parts.length === 1) {
    const { data } = await supabaseAdmin
      .from('players').select('id, nick')
      .eq('nick', decodeURIComponent(parts[0]).slice(0, 14)).maybeSingle();
    if (data) return Astro.redirect(`/u/${data.id}/${encodeURIComponent(data.nick)}`, 301);
  }
}
if (configured && !p) return Astro.redirect('/ranking', 302);

const nick = p?.players?.nick ?? parts.join('/') ?? '';
const pid = p?.players?.id ?? '';
const kd = p ? (p.deaths ? (p.kills / p.deaths).toFixed(2) : String(p.kills)) : '0';
const tempo = p ? displayTime(p) : '0min';
const badgeUrl = `${Astro.site}api/badge/${pid}.png`;
const pageUrl = `${Astro.site}u/${pid}/${encodeURIComponent(nick)}`;
const title = `${nick} no CS BRASIL: Treta Suprema`;
const desc = p ? `${p.kills} kills · K/D ${kd} · ${p.wins > 0 ? p.wins : "—"} vitórias · ${p.headshots} headshots · ${tempo} de arena` : 'Perfil de jogador';
---
<Layout title={title} description={desc} ogImage={badgeUrl}>
  <Fragment slot="head">
    <meta property="og:type" content="profile">
    <meta property="og:image:width" content="840">
    <meta property="og:image:height" content="440">
  </Fragment>
  {!configured && <h1>{nick}</h1><p>Ranking ainda não configurado.</p>}
  {p && (
    <>
      <div style="display:flex;align-items:center;gap:16px">
        {(() => {
          const av = p.players.avatar_url || socialAvatar(p.players.social_link);
          if (av) return <img src={av} alt={`Avatar de ${nick}`} width="72" height="72" style="border-radius:50%;border:2px solid #4a5a2a;object-fit:cover">;
          if (p.last_character && CHARS[p.last_character]) {
            const [, sc] = sideOf(p.matches_p, p.matches_b);
            return (
              <svg width="72" height="72" viewBox="688 36 120 120" style="border-radius:50%;border:2px solid #4a5a2a;background:#161a12">
                <Fragment set:html={charSvg(p.last_character, sc, 'cav-head')} />
              </svg>
            );
          }
          return <div style="width:72px;height:72px;border-radius:50%;border:2px solid #4a5a2a;background:#161a12;display:flex;align-items:center;justify-content:center;font-size:34px;color:var(--cs);font-family:'Arial Black',sans-serif">{p.nick[0].toUpperCase()}</div>;
        })()}
        <div>
          <h1 style="margin-bottom:4px">{nick}</h1>
          <div>
            {(p.players.socials?.length ? p.players.socials : (p.players.social_link ? [{ net: socialNet(p.players.social_link), url: p.players.social_link }] : [])).map((s: any) => {
              const net = s.net || socialNet(s.url), info = NET_INFO[net] || NET_INFO.site;
              return (
                <a href={s.url} target="_blank" rel="noopener" title={info.label}
                   style={`display:inline-block;min-width:24px;height:24px;line-height:24px;text-align:center;margin-right:6px;font-size:11px;font-weight:bold;color:${info.color};border:1px solid ${info.color};padding:0 5px;text-decoration:none`}>
                  {info.short}
                </a>
              );
            })}
          </div>
        </div>
      </div>
      <p style="margin-top:0">
        <span style="color:#ff8080">{p.matches_p} partidas de Petista</span> ×
        <span style="color:#9dff9d">{p.matches_b} de Bolsonarista</span>
      </p>
      <img src={`/api/badge/${pid}.png`} alt={`Badge de ${nick} no CS BRASIL`} width="840" height="440" style="width:100%;max-width:840px;border-radius:10px;border:1px solid #3a3325">
      <h2>Stats</h2>
      <div class="tstat">
        <div><b>{p.matches}</b><span>partidas</span></div>
        <div><b>{p.wins > 0 ? p.wins : "—"}</b><span>vitórias</span></div>
        <div><b>{p.rounds}</b><span>rounds</span></div>
        <div><b>{kd}</b><span>K/D</span></div>
        <div><b>{p.kills}</b><span>kills</span></div>
        <div><b>{p.deaths}</b><span>mortes</span></div>
        <div><b>{p.headshots}</b><span>headshots</span></div>
        <div><b>{p.best_streak}×</b><span>melhor sequência</span></div>
        <div><b>{tempo}</b><span>tempo de arena</span></div>
      </div>
      <h2>Compartilhar</h2>
      <p>
        <a class="btn-play" style="padding:10px 22px;border-radius:5px;text-decoration:none" target="_blank" rel="noopener"
           href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`Meu placar no CS BRASIL: ${p.kills} kills, K/D ${kd}, ${p.headshots} headshots. E aí, aguenta a treta?`)}&url=${encodeURIComponent(pageUrl)}`}>
          Postar no X</a>
        <button class="btn-play" style="padding:10px 22px;border-radius:5px;border:0;cursor:pointer;margin-left:10px"
                onclick={`navigator.clipboard.writeText('${pageUrl}').then(()=>this.textContent='Link copiado!')`}>
          Copiar link</button>
      </p>
      <p style="font-size:13px">Ao compartilhar, a badge acima aparece automaticamente no card da rede social.</p>
    </>
  )}
</Layout>
